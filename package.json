{
  "name": "quickzap",
  "version": "1.0.0",
  "description": "Open WhatsApp instantly from any phone number format",
  "main": "main.js",
  "scripts": {
    "start": "open -n node_modules/electron/dist/Electron.app --args $PWD",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.quickzap.app",
    "productName": "QuickZap",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "identity": null
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "zip",  "arch": ["x64", "arm64"] }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.0.0"
  }
}
