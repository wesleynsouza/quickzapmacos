{
  "name": "quickzap",
  "version": "1.0.0",
  "description": "Open WhatsApp instantly from any phone number format",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.quickzap.app",
    "productName": "QuickZap",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis", "portable"]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**/*",
      "!assets/*.png"
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
